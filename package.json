{
  "name": "@kozen/pipeline",
  "version": "1.0.0",
  "description": "Module for the Kozen framework that provides support for key vault secret managers.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/*",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "publish": "npm publish --access public",
    "mcp:start": "ts-node bin/kozen.ts --type=mcp",
    "start": "npm run bin:kozen:js --config=kozen.js.json",
    "dev": "npm run bin:kozen:ts --config=kozen.ts.json",
    "build": "tsc && npm run copy:txt",
    "test": "echo \"Error: no test specified\" && exit 1",
    "copy:txt": "copyfiles -u 1 src/**/*.txt dist/",
    "bin:kozen:ts": "ts-node node_modules/@kozen/engine/dist/bin/kozen.js",
    "bin:kozen:js": "npx kozen"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kozen-labs/pipeline.git"
  },
  "keywords": [
    "kozen",
    "mongodb",
    "secret manager",
    "key vault"
  ],
  "author": "Kozen Labs",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/kozen-labs/pipeline/issues"
  },
  "homepage": "https://github.com/kozen-labs/pipeline/wiki",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.917.0",
    "@kozen/engine": "^1.1.15",
    "mongodb": "^6.17.0",
    "mongodb-client-encryption": "^6.5.0"
  },
  "devDependencies": {
    "@types/node": "^18.19.127",
    "copyfiles": "^2.4.1",
    "cross-env": "^7.0.3",
    "ts-node": "^10.9.0",
    "tslint": "^6.1.3",
    "typescript": "^5.0.0"
  }
}
